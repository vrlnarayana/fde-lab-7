# -----------------------------------------------------------------------------
# Lab 7 environment file.
# 1) Copy this file to ".env"   ->   cp .env.example .env
# 2) Fill in the values from your Azure portal (see the lab guide, Part 4).
# 3) NEVER commit the real .env to git. Keep your keys private.
# -----------------------------------------------------------------------------

# --- Azure AI Search ---
AZURE_SEARCH_ENDPOINT=https://YOUR-SEARCH-SERVICE.search.windows.net
AZURE_SEARCH_KEY=YOUR-SEARCH-ADMIN-KEY
AZURE_SEARCH_INDEX=carepathways-idx

# --- Azure OpenAI (chat + embeddings live under one resource) ---
AZURE_OPENAI_ENDPOINT=https://YOUR-AOAI-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=YOUR-AOAI-KEY
AZURE_OPENAI_API_VERSION=2024-10-21

# Deployment NAMES you created in Azure AI Foundry (not model names).
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
